---
interface Props {
  title: string;
  body: string;
  badge?: string;
}
const { title, body, badge } = Astro.props;
---
<article class="rounded-sm border border-line bg-panel/60 px-5 py-5 flex flex-col gap-2">
  {badge && (
    <span class="text-[9px] tracking-widest uppercase text-neon-pink">{badge}</span>
  )}
  <h3 class="text-[15px] font-semibold text-ink">{title}</h3>
  <p class="text-[12px] text-muted leading-relaxed">{body}</p>
</article>
