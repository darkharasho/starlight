---
const title = 'Starlight — coming soon';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <style>
      :root { color-scheme: dark; }
      body {
        margin: 0; min-height: 100vh; display: grid; place-items: center;
        background: #07070b; color: #e5e7eb;
        font: 16px/1.5 system-ui, -apple-system, sans-serif;
      }
      main { text-align: center; max-width: 36ch; }
      h1 { color: #67e8f9; font-size: 2.25rem; margin: 0 0 0.5rem; letter-spacing: 0.05em; }
      a { color: #67e8f9; }
    </style>
  </head>
  <body>
    <main>
      <h1>Starlight</h1>
      <p>Open-source, community-driven game trainers.</p>
      <p><a href="https://github.com/darkharasho/starlight">github.com/darkharasho/starlight</a></p>
    </main>
  </body>
</html>
