---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import FeatureCard from '../components/FeatureCard.astro';
import Screenshot from '../components/Screenshot.astro';

const baseUrl = import.meta.env.BASE_URL;
const downloadHref = 'https://github.com/darkharasho/starlight/releases/latest';
---
<Base title="Starlight — open-source game trainers">
  <Hero downloadHref={downloadHref} />

  <section class="max-w-5xl mx-auto px-6 py-16">
    <div class="text-[10px] tracking-widest uppercase text-muted mb-3">Why Starlight</div>
    <h2 class="text-2xl font-semibold mb-8">Built around the way you actually play.</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <FeatureCard
        badge="Library"
        title="Sees every game you own"
        body="Auto-detects installed games from Steam, Epic, Heroic, and Lutris. Add manual entries for the few that slip through. Tile boxart pulls from Steam's CDN with a SteamGridDB fallback for non-Steam games."
      />
      <FeatureCard
        badge="Hotkeys"
        title="Real global hotkeys"
        body="Toggle, increment, and decrement value cheats from inside the game. Rebind any cheat per trainer — overrides persist. Built on Electron's globalShortcut, with conflict detection so you don't double-bind."
      />
      <FeatureCard
        badge="Catalog"
        title="An open community catalog"
        body="Trainers live in a public GitHub repo, indexed weekly from fearlessrevolution. Browse the full list in-app or fetch the JSON yourself. Want to add a game? Send a PR with one line of YAML."
      />
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-6 pb-20">
    <div class="text-[10px] tracking-widest uppercase text-muted mb-3">Inside the app</div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <Screenshot
        src={`${baseUrl}/screenshots/library.svg`}
        alt="Starlight Library tab showing game tiles with Trainer and Running badges"
        caption="Library — auto-detected games with trainer and running badges."
      />
      <Screenshot
        src={`${baseUrl}/screenshots/trainer.svg`}
        alt="Starlight Active Trainer tab with God Mode toggle and Speed value cheat"
        caption="Active Trainer — toggle and value cheats with global hotkeys."
      />
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mt-5">
      <Screenshot
        src={`${baseUrl}/screenshots/settings.svg`}
        alt="Starlight Settings tab with poll interval and refresh-on-launch options"
        caption="Settings — preferences persist to your user config."
      />
      <div class="rounded-sm border border-line bg-panel/40 p-5 flex flex-col justify-center gap-2">
        <div class="text-[10px] tracking-widest uppercase text-neon-pink">Open Source</div>
        <div class="text-[15px] font-semibold">MIT licensed. PRs welcome.</div>
        <p class="text-[12px] text-muted leading-relaxed">
          Code lives at <a href="https://github.com/darkharasho/starlight">github.com/darkharasho/starlight</a>.
          The trainer catalog lives in the same repo under <code class="text-neon-cyan font-mono">packages/catalog/</code>
          and is published to <a href={`${baseUrl}/catalog/index.json`}>{baseUrl}/catalog/index.json</a> on every push.
        </p>
      </div>
    </div>
  </section>
</Base>
